import argparse
import os
import signal
import subprocess
import sys
import tempfile
import threading


def parse_args():
    parser = argparse.ArgumentParser(
        prog='cyclictest',
        description='cyclictest-compatible wrapper for latmus (EVL)',
        add_help=False,
    )

    # --- Options mapped to latmus functionality ---
    parser.add_argument('-a', '--affinity', nargs='?', const='', default=None,
                        help='CPU affinity (e.g. 0,2,4 or 0-3)')
    parser.add_argument('-d', '--distance', type=int, default=500,
                        help='Distance between thread intervals in us')
    parser.add_argument('-D', '--duration', default=None,
                        help='Duration (e.g. 5m, 1h, 30s)')
    parser.add_argument('-h', '--histogram', type=int, default=0,
                        help='Histogram size in us')
    parser.add_argument('-H', '--histofall', type=int, default=0,
                        help='Like -h but with an additional TOTAL column')
    parser.add_argument('--histfile', default=None,
                        help='Write histogram to file instead of stdout')
    parser.add_argument('-i', '--interval', type=int, default=1000,
                        help='Base interval of thread in us')
    parser.add_argument('-l', '--loops', type=int, default=0,
                        help='Number of loops (0 = infinite)')
    parser.add_argument('-N', '--nsecs', action='store_true',
                        help='Print results in ns instead of us')
    parser.add_argument('-p', '--priority', type=int, default=80,
                        help='RT priority of highest prio thread')
    parser.add_argument('-q', '--quiet', action='store_true',
                        help='Only print summary on exit')
    parser.add_argument('-S', '--smp', action='store_true',
                        help='SMP testing: one thread per CPU, equal priority')
    parser.add_argument('-t', '--threads', nargs='?', type=int,
                        const=0, default=None,
                        help='Number of threads (no value = num CPUs)')
    parser.add_argument('-u', '--unbuffered', action='store_true',
                        help='Force unbuffered output')

    # --- Options accepted for CLI compatibility (ignored by latmus) ---
    parser.add_argument('-A', '--aligned', nargs='?', const='0', default=None,
                        help='(ignored) Align thread wakeups')
    parser.add_argument('-b', '--breaktrace', type=int, default=0,
                        help='(ignored) Breaktrace threshold in us')
    parser.add_argument('-c', '--clock', type=int, default=0,
                        help='(ignored) Select clock (0=MONOTONIC, 1=REALTIME)')
    parser.add_argument('--deepest-idle-state', type=int, default=None,
                        help='(ignored) Limit idle state depth')
    parser.add_argument('--default-system', action='store_true',
                        help='(ignored) Do not tune power management')
    parser.add_argument('-e', '--latency', type=int, default=0,
                        help='(ignored) /dev/cpu_dma_latency target value')
    parser.add_argument('-F', '--fifo', default=None,
                        help='(ignored) FIFO path for stats output')
    parser.add_argument('--json', default=None,
                        help='(ignored) Write JSON results to file')
    parser.add_argument('--laptop', action='store_true',
                        help='(ignored) Save battery')
    parser.add_argument('-m', '--mlockall', action='store_true',
                        help='(ignored) Lock memory')
    parser.add_argument('--mainaffinity', default=None,
                        help='(ignored) Main thread CPU affinity')
    parser.add_argument('-M', '--refresh_on_max', action='store_true',
                        help='(ignored) Refresh screen only on new max')
    parser.add_argument('-n', '--nanosleep', action='store_true',
                        help='(ignored) Use clock_nanosleep')
    parser.add_argument('-o', '--oscope', type=int, default=1,
                        help='(ignored) Oscilloscope mode reduction')
    parser.add_argument('--policy', default=None,
                        help='(ignored) Scheduling policy')
    parser.add_argument('--priospread', action='store_true',
                        help='(ignored) Spread priority levels')
    parser.add_argument('-r', '--relative', action='store_true',
                        help='(ignored) Use relative timer')
    parser.add_argument('-R', '--resolution', action='store_true',
                        help='(ignored) Check clock resolution')
    parser.add_argument('--secaligned', nargs='?', const='0', default=None,
                        help='(ignored) Second-aligned wakeups')
    parser.add_argument('-s', '--system', action='store_true',
                        help='(ignored) Use sys_nanosleep')
    parser.add_argument('--smi', action='store_true',
                        help='(ignored) Enable SMI counting')
    parser.add_argument('--spike', type=int, default=0,
                        help='(ignored) Record spikes above threshold')
    parser.add_argument('--spike-nodes', type=int, default=1024,
                        help='(ignored) Max spike recording nodes')
    parser.add_argument('--tracemark', action='store_true',
                        help='(ignored) Write trace mark on breaktrace')
    parser.add_argument('-v', '--verbose', action='store_true',
                        help='(ignored) Verbose per-sample output')
    parser.add_argument('-x', '--posix_timers', action='store_true',
                        help='(ignored) Use POSIX timers')
    parser.add_argument('--dbg_cyclictest', action='store_true',
                        help='(ignored) Debug output')

    parser.add_argument('--help', action='help')

    args = parser.parse_args()

    # -H is the same as -h but sets histofall mode
    if args.histofall > 0 and args.histogram == 0:
        args.histogram = args.histofall

    return args


def get_online_cpus():
    """Get sorted list of online CPU IDs available to this process."""
    return sorted(os.sched_getaffinity(0))


def parse_affinity(spec, online_cpus):
    """Parse cyclictest affinity spec: '0', '0,2,4', '0-3', or '' (all)."""
    spec = spec.strip()
    if not spec:
        return list(online_cpus)

    cpus = []
    for part in spec.split(','):
        part = part.strip()
        if '-' in part:
            lo, hi = part.split('-', 1)
            cpus.extend(range(int(lo), int(hi) + 1))
        else:
            cpus.append(int(part))

    available = set(online_cpus)
    return [c for c in cpus if c in available] or list(online_cpus)


def determine_thread_config(args):
    """Return list of (cpu_id, priority, interval_us) per measurement thread.

    Mimics cyclictest thread assignment:
      -S          one thread per CPU, all same priority
      -t [N]      N threads (default = num CPUs), priority decrements
      (neither)   single thread

    When histogram mode is active, cyclictest forces the same interval
    on all threads (distance stagger is disabled).
    """
    online_cpus = get_online_cpus()
    num_cpus = len(online_cpus)

    # cyclictest disables distance stagger when histogram is used
    dist = 0 if args.histogram > 0 else args.distance

    if args.smp:
        return [(cpu, args.priority, args.interval + i * dist)
                for i, cpu in enumerate(online_cpus)]

    if args.threads is not None:
        n = args.threads if args.threads > 0 else num_cpus
        if args.affinity is not None:
            cpus = parse_affinity(args.affinity, online_cpus)
        else:
            cpus = online_cpus
        n = min(n, len(cpus))
        return [(cpus[i], args.priority, args.interval + i * dist)
                for i in range(n)]

    # Single thread (default)
    if args.affinity is not None:
        cpu = parse_affinity(args.affinity, online_cpus)[0]
    else:
        cpu = None
    return [(cpu, args.priority, args.interval)]


def loops_to_timeout(loops, interval_us):
    """Convert loop count + interval to a timeout string for latmus -T."""
    total_secs = (loops * interval_us) / 1_000_000
    if total_secs < 1:
        return '1s'
    return f'{int(total_secs)}s'


def build_latmus_cmd(args, cpu, priority, interval, plot_file):
    """Build latmus command for one measurement thread.

    Uses --user (long form) because the short -u is broken in latmus
    due to its getopt_long .flag mechanism.
    """
    cmd = ['latmus', '-m', '--user']

    cmd.extend(['-p', str(interval)])
    cmd.extend(['-P', str(priority)])

    if cpu is not None:
        cmd.extend(['-c', str(cpu)])

    if args.loops > 0:
        cmd.extend(['-T', loops_to_timeout(args.loops, interval)])

    if args.duration is not None:
        cmd.extend(['-T', args.duration])

    if args.histogram > 0:
        cmd.append(f'-H{args.histogram}')
        if plot_file:
            cmd.append(f'-g{plot_file}')

    return cmd


def parse_latmus_output(output):
    """Parse the last RTD| line for run-wide statistics.

    RTD| format: min | avg | max | overruns | msw | best | worst
    Fields 'best' and 'worst' (indices 6, 7) track the extremes across
    the entire run, not just the last reporting bulk.
    """
    best = worst = avg = 0.0
    overrun = msw = 0

    for line in output.splitlines():
        if line.startswith('RTD|'):
            parts = [p.strip() for p in line.split('|')]
            if len(parts) >= 8:
                avg = float(parts[2])
                overrun = int(parts[4])
                msw = int(parts[5])
                best = float(parts[6])
                worst = float(parts[7])

    return best, avg, worst, overrun, msw


def read_histogram(plot_file, num_buckets):
    """Read latmus gnuplot histogram file.

    Returns (buckets_dict, total_count, overflow_count).
    The gnuplot file has one 'bucket count' line per bin; comment lines
    start with '#'.  The last bin may carry a '+' suffix indicating outliers.
    """
    buckets = {}
    total = 0
    overflow = 0

    if not plot_file or not os.path.exists(plot_file):
        return buckets, 0, 0

    with open(plot_file, 'r') as f:
        for line in f:
            line = line.strip()
            if line.startswith('#') or not line:
                continue
            parts = line.split()
            if len(parts) >= 2:
                idx = int(float(parts[0].rstrip('+')))
                count = int(parts[1])
                if idx < num_buckets:
                    buckets[idx] = count
                    total += count
                else:
                    overflow += count

    return buckets, total, overflow


def histogram_avg(buckets):
    """Compute weighted average latency from histogram bucket data."""
    total = sum(buckets.values())
    if total == 0:
        return 0.0
    return sum(k * v for k, v in buckets.items()) / total


def format_summary(idx, pid, priority, interval, use_nsecs,
                   lat_min, lat_avg, lat_max, loops):
    """Format one cyclictest T: summary line.

    cyclictest format (us):
      T:%2d (%5d) P:%2d I:%ld C:%7lu Min:%7ld Act:%5ld Avg:%5ld Max:%8ld
    cyclictest format (ns):
      T:%2d (%5d) P:%2d I:%ld C:%7lu Min:%7ld Act:%8ld Avg:%8ld Max:%8ld
    """
    if use_nsecs:
        imin = max(0, int(round(lat_min * 1000)))
        iavg = max(0, int(round(lat_avg * 1000)))
        imax = max(0, int(round(lat_max * 1000)))
        return (
            f"T:{idx:2d} ({pid:5d}) P:{priority:2d} I:{interval} "
            f"C:{loops:7d} "
            f"Min:{imin:7d} Act:{iavg:8d} Avg:{iavg:8d} Max:{imax:8d}"
        )
    else:
        imin = max(0, int(round(lat_min)))
        iavg = max(0, int(round(lat_avg)))
        imax = max(0, int(round(lat_max)))
        return (
            f"T:{idx:2d} ({pid:5d}) P:{priority:2d} I:{interval} "
            f"C:{loops:7d} "
            f"Min:{imin:7d} Act:{iavg:5d} Avg:{iavg:5d} Max:{imax:8d}"
        )


def print_hist(fd, args, num_threads, thread_hists, thread_stats,
               thread_totals, thread_overflows):
    """Print histogram in cyclictest-compatible format.

    cyclictest format:
      - Tab-separated columns, 6-digit zero-padded values
      - All-zero rows are skipped
      - With -H (histofall) and >1 threads, an extra TOTAL column is appended
    """
    histofall = args.histofall > 0 and num_threads > 1

    fd.write("# Histogram\n")
    for b in range(args.histogram):
        counts = [thread_hists[i].get(b, 0) for i in range(num_threads)]
        if sum(counts) == 0:
            continue
        fd.write(f"{b:06d} ")
        fd.write("\t".join(f"{c:06d}" for c in counts))
        if histofall:
            fd.write(f"\t{sum(counts):06d}")
        fd.write("\n")

    fd.write("# Min Latencies:")
    for i in range(num_threads):
        fd.write(f" {max(0, int(round(thread_stats[i][0]))):05d}")
    fd.write("\n")

    fd.write("# Avg Latencies:")
    for i in range(num_threads):
        fd.write(f" {max(0, int(round(thread_stats[i][1]))):05d}")
    fd.write("\n")

    fd.write("# Max Latencies:")
    maxmax = 0
    for i in range(num_threads):
        v = max(0, int(round(thread_stats[i][2])))
        fd.write(f" {v:05d}")
        maxmax = max(maxmax, v)
    if histofall:
        fd.write(f" {maxmax:05d}")
    fd.write("\n")

    fd.write("# Histogram Overflows:")
    all_overflows = 0
    for i in range(num_threads):
        fd.write(f" {thread_overflows[i]:05d}")
        all_overflows += thread_overflows[i]
    if histofall:
        fd.write(f" {all_overflows:05d}")
    fd.write("\n")

    fd.write("# Histogram Overflow at cycle number:\n")
    for i in range(num_threads):
        fd.write(f"# Thread {i}:\n")

    fd.write("\n")


def main():
    args = parse_args()

    if args.unbuffered:
        sys.stdout = os.fdopen(sys.stdout.fileno(), 'w', buffering=1)

    threads = determine_thread_config(args)
    num_threads = len(threads)

    # Create temp plot file paths for histogram mode.
    # Only generate names — do not create the files, because latmus
    # refuses to overwrite an existing file via -g.
    plot_files = []
    if args.histogram > 0:
        tmpdir = tempfile.gettempdir()
        for i in range(num_threads):
            path = os.path.join(
                tmpdir, f'latmus_{os.getpid()}_t{i}.plot')
            plot_files.append(path)
    else:
        plot_files = [None] * num_threads

    try:
        # Start one latmus instance per thread, each pinned to its CPU
        procs = []
        for i, (cpu, priority, interval) in enumerate(threads):
            cmd = build_latmus_cmd(
                args, cpu, priority, interval, plot_files[i])
            print(f"# Thread {i}: {' '.join(cmd)}", file=sys.stderr)
            proc = subprocess.Popen(
                cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                text=True,
            )
            procs.append(proc)

        # Forward signals to all children so they exit cleanly
        def forward_signal(signum, frame):
            for p in procs:
                try:
                    p.send_signal(signum)
                except ProcessLookupError:
                    pass

        signal.signal(signal.SIGINT, forward_signal)
        signal.signal(signal.SIGTERM, forward_signal)

        # Collect output from all processes in parallel to avoid
        # pipe-buffer deadlocks when multiple instances run concurrently.
        results = [None] * num_threads

        def _collect(idx, proc):
            stdout, stderr = proc.communicate()
            results[idx] = (proc.returncode, stdout, stderr)

        collectors = []
        for i, proc in enumerate(procs):
            t = threading.Thread(target=_collect, args=(i, proc))
            t.start()
            collectors.append(t)
        for t in collectors:
            t.join()

        for i, (rc, _, stderr) in enumerate(results):
            if rc not in (0, -2, -signal.SIGINT):
                print(f"latmus thread {i} failed (exit {rc}): {stderr}",
                      file=sys.stderr)

        # Parse per-thread statistics
        thread_stats = []
        for i, (_, stdout, stderr) in enumerate(results):
            thread_stats.append(parse_latmus_output(stdout + stderr))

        # Read per-thread histograms
        thread_hists = []
        thread_totals = []
        thread_overflows = []
        if args.histogram > 0:
            for i in range(num_threads):
                buckets, total, overflow = read_histogram(
                    plot_files[i], args.histogram)
                thread_hists.append(buckets)
                thread_totals.append(total)
                thread_overflows.append(overflow)

            # Recompute average from histogram for better accuracy
            for i in range(num_threads):
                havg = histogram_avg(thread_hists[i])
                if havg > 0:
                    lat_min, _, lat_max, overrun, msw = thread_stats[i]
                    thread_stats[i] = (lat_min, havg, lat_max, overrun, msw)

        # --- Format cyclictest-compatible output ---
        print(f"# /dev/cpu_dma_latency set to {args.latency}us")

        print("# Thread Ids:", end='')
        for proc in procs:
            print(f" {proc.pid:05d}", end='')
        print()

        for i, (cpu, priority, interval) in enumerate(threads):
            lat_min, lat_avg, lat_max, _, _ = thread_stats[i]
            if args.histogram > 0:
                loops = thread_totals[i]
            elif args.loops > 0:
                loops = args.loops
            else:
                loops = 0
            print(format_summary(i, procs[i].pid, priority, interval,
                                 args.nsecs,
                                 lat_min, lat_avg, lat_max, loops))

        if args.histogram > 0:
            if args.histfile:
                with open(args.histfile, 'w') as hf:
                    print_hist(hf, args, num_threads, thread_hists,
                               thread_stats, thread_totals, thread_overflows)
            else:
                print_hist(sys.stdout, args, num_threads, thread_hists,
                           thread_stats, thread_totals, thread_overflows)

        for i in range(num_threads):
            _, _, _, overrun, msw = thread_stats[i]
            if overrun > 0:
                print(f"# WARNING: Thread {i}: {overrun} timer overruns",
                      file=sys.stderr)
            if msw > 0:
                print(f"# WARNING: Thread {i}: {msw} mode switches",
                      file=sys.stderr)

    finally:
        for pf in plot_files:
            if pf and os.path.exists(pf):
                os.unlink(pf)


if __name__ == '__main__':
    main()
